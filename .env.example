PORT=3050
NODE_ENV=development

# כתובת פורטל Beast (לא הפורט של האפליקציה הזו!)
BEAST_PORTAL_URL=http://localhost:3000
APP_ID=beast-complaints
# כתובת ציבורית של האפליקציה (לצרכי SSO/SLO).
APP_URL=http://localhost:5180

# db-smart PostgreSQL (אותו DB שמחזיק את datasets)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=db_smart
DB_USER=db_smart
DB_PASSWORD=changeme_db_smart_password

# מזהה ה-dataset של "פניות לקוח" ב-db-smart (חייב להיווצר דרך db-smart UI לפני הפעלה ראשונה)
COMPLAINTS_DATASET_ID=

# קבוצת AD שתקבל הרשאות "מנהל מערכת" (גישה מלאה + מסומנת כקבוצת מנהלים)
ADMIN_GROUP=tichnun

# מפתח התפקיד ב-Beast user_roles שמסמן "נע"ט פניות לקוח" (מי שמנתב פניות)
NAVIGATOR_ROLE_KEY=naat_pniot_lakoach

# מפתחות תפקידי Beast שיזוהו כמנהלים (יוכלו לכתוב התייחסות מנהל ולסגור פניות).
# ברירת מחדל: madr (מד"ר). מופרד בפסיק לתמיכה בכמה מפתחות.
MANAGER_ROLE_KEYS=madr

# שם קבוצת AD של "קבע" — חברי קבוצה זו רואים את כל הפניות במערכת
# ויכולים לנתב פניות, אך *רק* לקבוצות שהם חברים בהן בעצמם.
KEVA_GROUP=keva

# רשימת קבוצות AD שמותרות לקבל פניות (מופרדות בפסיק).
# קבוצת keva איננה יעד ניתוב — היא רק מסמנת "סופר חבר צוות".
TARGET_GROUPS=tet,yod,yod_a,yod_b,handesaim,tichnun,minhala,mechonot

# מפתח API של האפליקציה ב-Beast (אופציונלי — מאפשר logs, notifications, וקריאה ל-AD directory)
BEAST_API_KEY=
BEAST_SECRET_KEY=

# אופציונלי: override לכתובת Beast בצד הלקוח. ברירת מחדל — BEAST_PORTAL_URL למעלה.
# VITE_PORTAL_URL=http://your-beast-host

# אופציונלי: שינוי פורט אם 3050 תפוס
# PORT=3051

# --- Gmail (אופציונלי — ברירת מחדל מנוהל מטאב "ניהול" ב-UI) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3050/api/settings/email/oauth/callback
# EMAIL_TOKEN_ENCRYPTION_KEY=
# EMAIL_FROM_NAME=פניות לקוח — ביסלת
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
