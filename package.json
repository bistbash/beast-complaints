{
  "name": "beast-complaints",
  "version": "1.0.0",
  "description": "ניהול פניות לקוח — מחובר ל-Beast SSO ול-db-smart",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite --host 0.0.0.0 --port 5180",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server.ts",
    "preview": "vite preview --host 0.0.0.0 --port 5180",
    "typecheck": "tsc --noEmit",
    "import-inquiries": "tsx scripts/import-inquiries.ts",
    "import-legacy-db": "tsx scripts/import-legacy-db.ts"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "pg": "^8.13.1",
    "puppeteer": "^24.43.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  }
}
